# Copy to .env and adjust as needed.
# Default is zero-setup SQLite. For Postgres use e.g.:
# DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/carpool
DATABASE_URL=sqlite:///./carpool.db
# Required — the app refuses to start without it.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=replace-with-a-generated-secret
ACCESS_TOKEN_MINUTES=15
GOOGLE_API_KEY=your-google-maps-api-key

# Public URL of the frontend (used in email links).
FRONTEND_URL=http://localhost:5173

# --- Email / SMTP (use a Gmail App Password, not your login password) ---
EMAIL_ENABLED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-sender@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_FROM_NAME=Carpool

# --- Razorpay (test mode) ---
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
